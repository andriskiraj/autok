<Window x:Class="autok.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:autok"
        mc:Ignorable="d"
        Title="Autók" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <Label Content="Autók" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="129" Height="67" FontSize="40"/>
        <StackPanel HorizontalAlignment="Left" Margin="684,0,0,0" Orientation="Vertical" VerticalAlignment="Center" Height="179">
            <Button x:Name="uj" Content="Új"  Width="75" Click="uj_Click_1"/>
            <Button x:Name="modositas" Content="Módosítás" Margin="0,20,0,0" Width="75" Click="modositas_Click_1"/>
            <Button x:Name="torles" Content="Törlés" Margin="0,20,0,0" Width="75" Click="torles_Click"/>
        </StackPanel>
        <Button x:Name="bezar" Content="Bezár" Click="bezar_Click_1" Margin="684,375,10,10"/>
        <Grid HorizontalAlignment="Left" Height="73" VerticalAlignment="Top" Width="512" Margin="24,339,0,0">
            <Label Content="Üzemanyag:" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Label Content="Szín:" HorizontalAlignment="Left" Margin="261,0,0,0" VerticalAlignment="Top" RenderTransformOrigin="3.418,0.741"/>
            <Label Content="Típus:" HorizontalAlignment="Left" Margin="258,40,0,0" VerticalAlignment="Top" RenderTransformOrigin="1.988,0.478"/>
            <Label Content="Km:" HorizontalAlignment="Left" Margin="9,40,0,0" VerticalAlignment="Top"/>
            <Label x:Name="uzemanyag" Content="" HorizontalAlignment="Left" Margin="94,0,0,0" VerticalAlignment="Top" Width="112"/>
            <Label x:Name="km" Content="" HorizontalAlignment="Left" Margin="94,47,0,0" VerticalAlignment="Top" Width="112"/>
            <Label x:Name="tipus" Content="" HorizontalAlignment="Left" Margin="324,40,0,0" VerticalAlignment="Top" Width="150"/>
            <Label x:Name="szin" Content="" HorizontalAlignment="Left" Margin="324,0,0,0" VerticalAlignment="Top" Width="75"/>

        </Grid>
        <TextBox x:Name="textbox" HorizontalAlignment="Left" Margin="24,0,0,0" TextWrapping="Wrap"
                 VerticalAlignment="Center" Width="382" Height="179" SelectionChanged="rendszamm" IsReadOnly="True"/>
        <Image x:Name="kep" HorizontalAlignment="Left" Height="179" Margin="443,128,0,0" VerticalAlignment="Top" Width="173" Source="/img/suzukiswift.jpg" >
            
        </Image>

    </Grid>
</Window>
