<Window x:Class="autok.UjAuto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:autok"
        mc:Ignorable="d"
        Title="UjAuto" Height="400" Width="300">
    <Grid>
        <Button x:Name="hozzaad" Content="Hozzáad" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,343,0,0"/>
        <Label Content="Új autó hozzáadása" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" FontWeight="Black" FontSize="25" Width="280"/>
        <Grid HorizontalAlignment="Center" Height="126" Margin="0,67,0,0" VerticalAlignment="Top" Width="148">
            <Label Content="Az autó rendszáma:" HorizontalAlignment="Center" VerticalAlignment="Top" FontWeight="Bold" FontSize="15" Height="33" Width="148"/>
            <TextBox HorizontalAlignment="Center" Margin="0,38,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"  Height="25" Width="126"/>
            <Label Content="Üzemanyag:" HorizontalAlignment="Center" VerticalAlignment="Top" FontWeight="Bold" FontSize="15" Height="33" Width="148" Margin="0,68,0,0"/>
            <TextBox HorizontalAlignment="Center" Margin="0,101,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"  Height="25" Width="126"/>

        </Grid>

    </Grid>
</Window>
